{
  "rewrites": [
    { "source": "/callback", "destination": "/callback.html" },
    { "source": "/profile",  "destination": "/profile.html"  },
    { "source": "/assets",   "destination": "/assets.html"    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
